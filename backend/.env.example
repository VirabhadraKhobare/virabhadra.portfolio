PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/virabhadra_portfolio
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
AUTH_COOKIE_NAME=portfolio.auth
CSRF_COOKIE_NAME=portfolio.csrf
COOKIE_SECURE=false
REQUEST_BODY_LIMIT=100kb
LOGIN_LOCKOUT_WINDOW_MS=900000
LOGIN_LOCKOUT_THRESHOLD=5
CONTACT_RATE_LIMIT_WINDOW_MS=3600000
CONTACT_RATE_LIMIT_MAX=5
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000
COOKIE_SECRET=replace_with_a_long_random_cookie_secret
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_token
LEETCODE_USERNAME=your_leetcode_username
CODEFORCES_HANDLE=your_codeforces_handle
HACKERRANK_HANDLE=your_hackerrank_handle
ACHIEVEMENTS_REFRESH_MS=43200000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password